# VilnoPayService v4.0 — конфігурація
# Скопіюй в .env та заповни

# Публічний URL сервісу
BASE_URL=https://pay.yourdomain.com

# Redis
REDIS_PASSWORD=your-strong-redis-password-here
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# PostgreSQL
PG_PASSWORD=your-strong-pg-password-here
DATABASE_URL=postgresql://vilnopay:${PG_PASSWORD}@postgres:5432/vilnopay

# Початковий адмін (тільки при першому запуску, потім видалити)
ADMIN_INIT_USER=admin
ADMIN_INIT_PASS=change-me-immediately

# Час сесії адміна (години)
SESSION_TTL_HOURS=8

# Дозволені хости
ALLOWED_HOSTS=pay.yourdomain.com

# Логування
LOG_LEVEL=INFO
