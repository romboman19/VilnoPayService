# VilnoPayService — приклад конфігурації
# Скопіюй в .env та заповни реальними значеннями

# API ключ для /generate та /qr.png (обов'язково змінити!)
API_KEY=your-strong-api-key-here

# Публічний URL сервісу (для генерації посилань)
BASE_URL=https://pay.yourdomain.com

# Час життя платіжного посилання (години)
LINK_TTL_HOURS=24

# Redis з паролем
REDIS_PASSWORD=your-strong-redis-password-here
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# Дозволені хости (через кому, * для всіх)
ALLOWED_HOSTS=pay.yourdomain.com

# Рівень логування: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
