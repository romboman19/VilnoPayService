# VilnoPayService .env example

# База даних
DATABASE_URL=postgresql://vilnopay:vilnopay@postgres:5432/vilnopay

# Redis
REDIS_URL=redis://redis:6379/0

# Адмін
ADMIN_INIT_USER=admin
ADMIN_INIT_PASS=changeme

# Базовий URL
BASE_URL=https://pay.yourdomain.com

# Дозволені хости
ALLOWED_HOSTS=pay.yourdomain.com

# Логування
LOG_LEVEL=INFO

# Шифрування ключiв платiжних провайдерiв (Fernet)
# Згенерувати: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PROVIDER_ENCRYPTION_KEY=your-fernet-key-here